  "recommendedV1Formula": {
    "grossPay": {
      "formula": "load.price",
      "notes": "Direct from database"
    },
    "totalMiles": {
      "formula": "load.miles (from normalizeLoadFinancials Haversine calculation)",
      "fallback": "120 miles if coordinates invalid"
    },
    "estimatedDriveTimeMinutes": {
      "formula": "totalMiles / 40 * 60",
      "notes": "Assume 40 mph average speed"
    },
    "serviceTimeMinutes": {
      "formula": "Math.max(itemCount || 1, 1) * 1.1",
      "fallback": "1.1 minutes if itemCount missing"
    },
    "estimatedTotalMinutes": {
      "formula": "Math.max(estimatedDriveTimeMinutes + serviceTimeMinutes + bufferMinutes, minimumEstimatedMinutes)",
      "bufferMinutes": 5,
      "minimumEstimatedMinutes": 15
    },
    "vehicleCost": {
      "formula": "totalMiles * vehicleCostPerMile",
      "vehicleCostPerMile": 0.179,
      "notes": "Cargo van operating cost per mile"
    },
    "netPay": {
      "formula": "grossPay - vehicleCost",
      "notes": "Net pay after vehicle operating costs"
    },
    "hourlyRate": {
      "formula": "estimatedTotalMinutes > 0 ? (netPay / estimatedTotalMinutes) * 60 : null",
      "notes": "Estimated hourly rate based on net pay and time"
    },
    "payPerMile": {
      "formula": "totalMiles > 0 ? netPay / totalMiles : null",
      "notes": "Net pay per mile"
    },
    "profitabilityScore": {
      "formula": "hourlyRate >= 25 ? 'healthy' : hourlyRate >= 20 ? 'at_risk' : 'loss'",
      "healthy": "hourlyRate >= $25/hour",
      "at_risk": "hourlyRate $20-$25/hour",
      "loss": "hourlyRate < $20/hour"
    }
  },

