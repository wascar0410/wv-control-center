# WV Control Center - Production Environment Configuration
# Copy this file to your hosting platform and set the actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=mysql://user:password@host:3306/wv_control_center

# ============================================================================
# AUTHENTICATION & OAUTH
# ============================================================================
JWT_SECRET=your-jwt-secret-key-here-min-32-chars-recommended
VITE_APP_ID=your-manus-oauth-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im/login

# ============================================================================
# HOST VALIDATION & CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed hosts (without protocol)
# These are the domains your server will accept requests from
ALLOWED_HOSTS=app.wvtransports.com,api.wvtransports.com,www.wvtransports.com

# Comma-separated list of allowed CORS origins (with protocol)
# These are the origins that can make cross-origin requests to your API
CORS_ORIGINS=https://app.wvtransports.com,https://api.wvtransports.com,https://www.wvtransports.com

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================
# Enable rate limiting (true/false)
RATE_LIMITING_ENABLED=true

# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window per host
RATE_LIMIT_MAX_REQUESTS=1000

# Maximum requests per window for suspicious hosts
RATE_LIMIT_SUSPICIOUS_MAX_REQUESTS=100

# ============================================================================
# SECURITY & MONITORING CONFIGURATION
# ============================================================================
# Enable host rejection monitoring and alerts
HOST_REJECTION_MONITORING_ENABLED=true

# Alert threshold: number of rejections before sending alert
HOST_REJECTION_ALERT_THRESHOLD=10

# Time window for counting rejections (in milliseconds, default: 1 hour)
HOST_REJECTION_ALERT_WINDOW_MS=3600000

# Enable automatic blocking of hosts with excessive rejections
AUTO_BLOCK_SUSPICIOUS_HOSTS=true

# Duration to block a suspicious host (in milliseconds, default: 24 hours)
SUSPICIOUS_HOST_BLOCK_DURATION_MS=86400000

# ============================================================================
# OWNER NOTIFICATION SETTINGS
# ============================================================================
# Enable notifications for security events
SECURITY_NOTIFICATIONS_ENABLED=true

# Notification level: 'critical', 'warning', 'info'
SECURITY_NOTIFICATION_LEVEL=warning

# ============================================================================
# MANUS BUILT-IN SERVICES
# ============================================================================
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# ============================================================================
# OWNER INFORMATION
# ============================================================================
OWNER_NAME=WV Transport LLC
OWNER_OPEN_ID=your-owner-open-id

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================
# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Plaid Integration (Banking)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=production

# Twilio Integration (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=your-twilio-messaging-service-sid

# ============================================================================
# ANALYTICS
# ============================================================================
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV=production
PORT=3000
VITE_APP_TITLE=WV Control Center
VITE_APP_LOGO=https://your-cdn.com/logo.png
