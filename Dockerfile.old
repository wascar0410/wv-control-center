# Build stage
FROM node:22-alpine AS builder

# Accept VITE_* build arguments from Railway
ARG VITE_GOOGLE_MAPS_API_KEY
ARG VITE_APP_ID
ARG VITE_OAUTH_PORTAL_URL
ARG VITE_FRONTEND_FORGE_API_URL
ARG VITE_FRONTEND_FORGE_API_KEY
ARG VITE_ANALYTICS_ENDPOINT
ARG VITE_ANALYTICS_WEBSITE_ID
ARG VITE_APP_TITLE
ARG VITE_APP_LOGO

# Export build args as environment variables for Vite
ENV VITE_GOOGLE_MAPS_API_KEY=$VITE_GOOGLE_MAPS_API_KEY
ENV VITE_APP_ID=$VITE_APP_ID
ENV VITE_OAUTH_PORTAL_URL=$VITE_OAUTH_PORTAL_URL
ENV VITE_FRONTEND_FORGE_API_URL=$VITE_FRONTEND_FORGE_API_URL
ENV VITE_FRONTEND_FORGE_API_KEY=$VITE_FRONTEND_FORGE_API_KEY
ENV VITE_ANALYTICS_ENDPOINT=$VITE_ANALYTICS_ENDPOINT
ENV VITE_ANALYTICS_WEBSITE_ID=$VITE_ANALYTICS_WEBSITE_ID
ENV VITE_APP_TITLE=$VITE_APP_TITLE
ENV VITE_APP_LOGO=$VITE_APP_LOGO

WORKDIR /app

RUN npm install -g pnpm@10.4.1

COPY package.json pnpm-lock.yaml ./

RUN pnpm install --no-frozen-lockfile

COPY . .

RUN echo "BUILD_FORCE_2026_04_05_1"

RUN rm -rf dist node_modules/.vite

# Diagnostic: Confirm VITE_GOOGLE_MAPS_API_KEY is available at build time (never print the actual key)
RUN echo "[Build Diagnostic] VITE_GOOGLE_MAPS_API_KEY available: ${VITE_GOOGLE_MAPS_API_KEY:+true}"

RUN pnpm build

# Production stage
FROM node:22-alpine AS runner

WORKDIR /app

RUN npm install -g pnpm@10.4.1

COPY package.json pnpm-lock.yaml ./

# Instala TODAS las dependencias porque el server necesita vite en runtime
RUN pnpm install --no-frozen-lockfile

COPY --from=builder /app/dist ./dist
COPY --from=builder /app/client/public ./client/public

ENV NODE_ENV=production

CMD ["pnpm", "start"]
